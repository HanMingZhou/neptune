{
  "name": "neptune-ai-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:unit": "vitest run",
    "check:no-js": "node ./scripts/check-no-js.mjs --strict",
    "check:no-console": "node ./scripts/check-no-console.mjs",
    "check:no-new-js": "node ./scripts/check-no-js.mjs --allow-file ./scripts/no-js-allowlist.json"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@unocss/reset": "^66.6.0",
    "@vueuse/core": "^14.1.0",
    "@vueuse/integrations": "^14.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ace-builds": "^1.43.6",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.1",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "marked-highlight": "^2.2.3",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "screenfull": "^6.0.2",
    "sortablejs": "^1.15.6",
    "universal-cookie": "^8.0.1",
    "unocss": "^66.6.0",
    "vue-cropper": "^0.6.5",
    "vue-router": "^4.6.4",
    "vue3-ace-editor": "^2.2.4",
    "vue3-sfc-loader": "^0.9.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.58.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.4.0"
  }
}
